# GeniusPrompts Backend Agent — Environment Variables
# Copy this to .env for local development
# On Railway, set these in the Variables tab

# Claude API (required for AI-generated content)
ANTHROPIC_API_KEY=sk-ant-...

# Beehiiv Newsletter Platform (required for email automation)
BEEHIIV_API_KEY=bh_...
BEEHIIV_PUBLICATION_ID=pub_...

# Server config
PORT=8080
TZ=America/New_York
DATA_DIR=/data
